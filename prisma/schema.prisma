// ViLearn � AI-powered Vietnamese learning platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------
// USERS
// ---------------------------------------------

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  passwordHash      String?   // null for OAuth-only accounts
  googleId          String?   @unique
  avatarUrl         String?
  role              Role      @default(USER)
  level             String?   // A1, A2, B1, B2, C1, C2
  goals             String[]  // e.g. ["travel", "business"]
  dailyGoal         Int?      // daily study goal in minutes (e.g. 10, 20, 30)
  lastLoginAt             DateTime? // updated on every successful login
  minutesStudiedToday     Int       @default(0)
  minutesStudiedTodayDate DateTime?
  // XP & streak fields
  xpTotal           Int       @default(0)
  xpToday           Int       @default(0)
  xpTodayDate       DateTime?
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastActivityDate  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  flashcardReviews FlashcardReview[]
  tutorSessions    TutorSession[]
  quizSessions     QuizSession[]
  stats            UserStats?
  customDecks      Deck[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ---------------------------------------------
// VOCAB / DECKS / FLASHCARDS
// ---------------------------------------------

model Deck {
  id          String    @id @default(cuid())
  name        String
  deckType    DeckType  @default(CUSTOM)
  description String?
  ownerId     String?   // null = system deck
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  flashcards  Flashcard[]

  @@map("decks")
}

enum DeckType {
  CORE
  TRAVEL
  BUSINESS
  CUSTOM
}

model Flashcard {
  id              String   @id @default(cuid())
  deckId          String
  word            String   // Vietnamese word
  pronunciation   String?  // phonetic / tones
  meaning         String   // English meaning
  partOfSpeech    String?  // noun | verb | adjective | adverb | pronoun | phrase | expression | interjection
  exampleSentence String?
  audioUrl        String?
  createdAt       DateTime @default(now())

  deck    Deck              @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews FlashcardReview[]

  @@map("flashcards")
}

// SRS per-user per-card state
model FlashcardReview {
  id            String   @id @default(cuid())
  userId        String
  flashcardId   String
  interval      Int      @default(1)   // days until next review
  easeFactor    Float    @default(2.5)
  repetitions   Int      @default(0)
  nextReviewAt  DateTime @default(now())
  lastRating    String?  // again | hard | good | easy
  reviewedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@map("flashcard_reviews")
}

// ---------------------------------------------
// AI TUTOR
// ---------------------------------------------

model TutorSession {
  id        String   @id @default(cuid())
  userId    String
  topic     String?
  mode      String   @default("free")  // explain | correct | free
  level     String   @default("A1")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TutorMessage[]

  @@map("tutor_sessions")
}

model TutorMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole // USER | ASSISTANT
  content   String
  metadata  Json?       // corrections, suggestions
  createdAt DateTime    @default(now())

  session TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("tutor_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

// ---------------------------------------------
// QUIZ
// ---------------------------------------------

model QuizSession {
  id         String          @id @default(cuid())
  userId     String
  questions  Json            // QuizQuestion[]
  isComplete Boolean         @default(false)
  score      Int?
  feedback   Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@map("quiz_sessions")
}

model QuizAnswer {
  id            String   @id @default(cuid())
  quizSessionId String
  questionId    String
  selectedId    String
  isCorrect     Boolean
  createdAt     DateTime @default(now())

  quizSession QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

// ---------------------------------------------
// CONTENT LESSONS
// ---------------------------------------------

model ContentLesson {
  id        String   @id @default(cuid())
  inputType String   // "text" | "topic"
  source    String?
  vocab     Json     // GeneratedVocabItem[]
  examples  Json     // string[]
  exercises Json     // Exercise[]
  createdAt DateTime @default(now())

  @@map("content_lessons")
}

// ---------------------------------------------
// STATS
// ---------------------------------------------

model UserStats {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalWords     Int      @default(0)
  totalReviews   Int      @default(0)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}
